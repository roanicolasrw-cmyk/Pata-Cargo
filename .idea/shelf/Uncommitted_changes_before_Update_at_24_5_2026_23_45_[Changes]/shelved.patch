diff --git a/app/src/main/java/com/example/data/FirestoreRepository.kt b/app/src/main/java/com/example/data/FirestoreRepository.kt
new file mode 100644
--- /dev/null	(date 1779673671034)
+++ b/app/src/main/java/com/example/data/FirestoreRepository.kt	(date 1779673671034)
@@ -0,0 +1,220 @@
+package com.example.data
+
+import com.google.firebase.firestore.FirebaseFirestore
+import com.google.firebase.firestore.Query
+import com.google.firebase.firestore.snapshots
+import com.google.firebase.firestore.toObject
+import com.google.firebase.firestore.toObjects
+import kotlinx.coroutines.flow.Flow
+import kotlinx.coroutines.flow.map
+import kotlinx.coroutines.tasks.await
+import java.util.UUID
+
+class FirestoreRepository {
+
+    private val firestore = FirebaseFirestore.getInstance()
+    private val usersCollection = firestore.collection("users")
+    private val shipmentsCollection = firestore.collection("shipments")
+    private val routesCollection = firestore.collection("routes")
+    private val offersCollection = firestore.collection("offers")
+    private val chatCollection = firestore.collection("chat_messages")
+    private val reviewsCollection = firestore.collection("reviews")
+
+    // --- USERS ---
+
+    fun getAllUsersFlow(): Flow<List<UserEntity>> = usersCollection.snapshots().map { it.toObjects() }
+
+    fun getUserByIdFlow(userId: String): Flow<UserEntity?> = 
+        usersCollection.document(userId).snapshots().map { it.toObject<UserEntity>() }
+
+    suspend fun getUserById(userId: String): UserEntity? = 
+        usersCollection.document(userId).get().await().toObject<UserEntity>()
+
+    suspend fun insertUser(user: UserEntity) {
+        usersCollection.document(user.id).set(user).await()
+    }
+
+    suspend fun updateUser(user: UserEntity) {
+        usersCollection.document(user.id).set(user).await()
+    }
+
+    fun getUsersPendingVerificationFlow(): Flow<List<UserEntity>> = 
+        usersCollection.whereEqualTo("verified", false)
+            .whereEqualTo("biometricVerified", true)
+            .snapshots().map { it.toObjects() }
+
+    // --- SHIPMENTS ---
+
+    fun getAllShipmentsFlow(): Flow<List<ShipmentEntity>> = 
+        shipmentsCollection.orderBy("timestamp", Query.Direction.DESCENDING).snapshots().map { it.toObjects() }
+
+    fun getPendingShipmentsFlow(): Flow<List<ShipmentEntity>> = 
+        shipmentsCollection.whereEqualTo("status", "PENDIENTE")
+            .orderBy("timestamp", Query.Direction.DESCENDING)
+            .snapshots().map { it.toObjects() }
+
+    fun getShipmentsBySenderFlow(senderId: String): Flow<List<ShipmentEntity>> = 
+        shipmentsCollection.whereEqualTo("senderId", senderId)
+            .orderBy("timestamp", Query.Direction.DESCENDING)
+            .snapshots().map { it.toObjects() }
+
+    fun getShipmentsByCarrierFlow(carrierId: String): Flow<List<ShipmentEntity>> = 
+        shipmentsCollection.whereEqualTo("carrierId", carrierId)
+            .orderBy("timestamp", Query.Direction.DESCENDING)
+            .snapshots().map { it.toObjects() }
+
+    fun getShipmentByIdFlow(shipmentId: Int): Flow<ShipmentEntity?> = 
+        shipmentsCollection.document(shipmentId.toString()).snapshots().map { it.toObject<ShipmentEntity>() }
+
+    suspend fun getShipmentById(shipmentId: Int): ShipmentEntity? = 
+        shipmentsCollection.document(shipmentId.toString()).get().await().toObject<ShipmentEntity>()
+
+    suspend fun insertShipment(shipment: ShipmentEntity): Long {
+        // Firestore doesn't have auto-incrementing Int IDs like Room. 
+        // We'll use a random Int for compatibility with existing models, 
+        // or better, use Firestore document IDs.
+        val id = (System.currentTimeMillis() % Int.MAX_VALUE).toInt()
+        val finalShipment = shipment.copy(id = id)
+        shipmentsCollection.document(id.toString()).set(finalShipment).await()
+        return id.toLong()
+    }
+
+    suspend fun updateShipment(shipment: ShipmentEntity) {
+        shipmentsCollection.document(shipment.id.toString()).set(shipment).await()
+    }
+
+    suspend fun updateShipmentStatus(shipmentId: Int, status: String) {
+        shipmentsCollection.document(shipmentId.toString()).update("status", status).await()
+    }
+
+    // --- ROUTES ---
+
+    fun getRoutesByCarrierFlow(carrierId: String): Flow<List<RouteEntity>> = 
+        routesCollection.whereEqualTo("carrierId", carrierId).snapshots().map { it.toObjects() }
+
+    suspend fun insertRoute(route: RouteEntity) {
+        val id = UUID.randomUUID().toString()
+        // We might need to adjust RouteEntity to handle String IDs or just use Firestore's ID
+        routesCollection.document(id).set(route).await()
+    }
+
+    suspend fun deleteRouteById(routeId: Int) {
+        // This is tricky because RouteEntity has an Int ID. 
+        // In a real cloud migration, we'd use String IDs.
+        routesCollection.whereEqualTo("id", routeId).get().await().forEach { it.reference.delete().await() }
+    }
+
+    // --- OFFERS ---
+
+    fun getOffersForShipmentFlow(shipmentId: Int): Flow<List<OfferEntity>> = 
+        offersCollection.whereEqualTo("shipmentId", shipmentId).snapshots().map { it.toObjects() }
+
+    suspend fun insertOffer(offer: OfferEntity) {
+        val id = UUID.randomUUID().toString()
+        offersCollection.document(id).set(offer).await()
+    }
+
+    suspend fun updateOfferStatus(offerId: Int, status: String) {
+        offersCollection.whereEqualTo("id", offerId).get().await().forEach { it.reference.update("status", status).await() }
+    }
+
+    suspend fun rejectOtherOffers(shipmentId: Int, acceptedOfferId: Int) {
+        offersCollection.whereEqualTo("shipmentId", shipmentId)
+            .get().await().forEach { 
+                val offer = it.toObject<OfferEntity>()
+                if (offer.id != acceptedOfferId) {
+                    it.reference.update("status", "RECHAZADO").await()
+                }
+            }
+    }
+
+    // --- CHAT ---
+
