# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# MERCADO_PAGO_ACCESS_TOKEN: Required for real Mercado Pago payments, customers creation & search.
# Set this to your Sandbox or Production Access Token from Mercado Pago Developers dashboard.
# (e.g. APP_USR-xxxxxxxxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxx)
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-8344075191242337-061618-9c16538e12ff9562768565aebcf4a1bb-2154867

